{
  "$schema": "http://www.lavishsoft.com/schema/lgui2Package.json",
  "templates": {
    "tabMissions.content": {
      "type": "panel",
      "horizontalAlignment": "stretch",
      "verticalAlignment": "stretch",
      "children": [
        {
          "type": "textblock",
          "name": "lblRunTheseTypes",
          "x": 10,
          "y": 20,
          "width": 300,
          "height": 54,
          "text": "Run These Types:",
          "font": {
            "height": 36,
            "bold": true
          }
        },
        {
          "jsonTemplate": "evebotBorderedPanel",
          "name": "frmMissionTypes",
          "x": 10,
          "y": 60,
          "width": 390,
          "height": 300,
          "children": [
            {
              "type": "checkbox",
              "name": "cbRunCourierMissions",
              "x": 30,
              "y": 30,
              "width": 330,
              "height": 60,
              "content": "Courier Missions",
              "contentContainer": {
                "jsonTemplate": "evebotCheckboxContainer"
              },
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "If checked, accept and complete courier missions."
              },
              "checkedBinding": {
                "pullFormat": "${Script[EVEBot].VariableScope.Config.Missioneer.RunCourierMissions}",
                "pushFormat": ["Script[EVEBot].VariableScope.Config.Missioneer:SetRunCourierMissions[", "]"]
              }
            },
            {
              "type": "checkbox",
              "name": "cbRunTradeMissions",
              "x": 30,
              "y": 90,
              "width": 330,
              "height": 60,
              "content": "Trade Missions",
              "contentContainer": {
                "jsonTemplate": "evebotCheckboxContainer"
              },
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "If checked, accept and complete trade missions."
              },
              "checkedBinding": {
                "pullFormat": "${Script[EVEBot].VariableScope.Config.Missioneer.RunTradeMissions}",
                "pushFormat": ["Script[EVEBot].VariableScope.Config.Missioneer:SetRunTradeMissions[", "]"]
              }
            },
            {
              "type": "checkbox",
              "name": "cbRunMiningMissions",
              "x": 30,
              "y": 150,
              "width": 330,
              "height": 60,
              "content": "Mining Missions",
              "contentContainer": {
                "jsonTemplate": "evebotCheckboxContainer"
              },
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "If checked, accept and complete mining missions."
              },
              "checkedBinding": {
                "pullFormat": "${Script[EVEBot].VariableScope.Config.Missioneer.RunMiningMissions}",
                "pushFormat": ["Script[EVEBot].VariableScope.Config.Missioneer:SetRunMiningMissions[", "]"]
              }
            },
            {
              "type": "checkbox",
              "name": "cbRunKillMissions",
              "x": 30,
              "y": 210,
              "width": 330,
              "height": 60,
              "content": "Kill Missions",
              "contentContainer": {
                "jsonTemplate": "evebotCheckboxContainer"
              },
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "If checked, accept and complete kill missions."
              },
              "checkedBinding": {
                "pullFormat": "${Script[EVEBot].VariableScope.Config.Missioneer.RunKillMissions}",
                "pushFormat": ["Script[EVEBot].VariableScope.Config.Missioneer:SetRunKillMissions[", "]"]
              }
            }
          ]
        },
        {
          "type": "textblock",
          "name": "lblShipNames",
          "x": 450,
          "y": 20,
          "width": 390,
          "height": 54,
          "text": "Ship Names:",
          "font": {
            "height": 36,
            "bold": true
          }
        },
        {
          "jsonTemplate": "evebotBorderedPanel",
          "name": "frmShipNames",
          "x": 450,
          "y": 60,
          "width": 800,
          "height": 300,
          "children": [
            {
              "type": "textblock",
              "name": "lblSmallHauler",
              "x": 30,
              "y": 40,
              "width": 300,
              "height": 54,
              "text": "Small Hauler:",
              "font": {
                "height": 36
              }
            },
            {
              "type": "textbox",
              "name": "tbSmallHauler",
              "x": 270,
              "y": 40,
              "width": 400,
              "height": 48,
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "Small Hauler (6000 m^3 or less)."
              },
              "eventHandlers": {
                "onLoad": {
                  "type": "code",
                  "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Missioneer.SmallHauler}]"
                },
                "onTextChanged": {
                  "type": "code",
                  "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetSmallHauler[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetSmallHauler[\"\"]\n}"
                },
                "onTabPress": {
                  "type": "code",
                  "code": "LGUI2.Element[tbLargeHauler]:KeyboardFocus"
                }
              },
              "font": {
                "height": 36
              }
            },
            {
              "type": "textblock",
              "name": "lblLargeHauler",
              "x": 30,
              "y": 100,
              "width": 300,
              "height": 54,
              "text": "Large Hauler:",
              "font": {
                "height": 36
              }
            },
            {
              "type": "textbox",
              "name": "tbLargeHauler",
              "x": 270,
              "y": 100,
              "width": 400,
              "height": 48,
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "Large Hauler (more than 6000 m^3)."
              },
              "eventHandlers": {
                "onLoad": {
                  "type": "code",
                  "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Missioneer.LargeHauler}]"
                },
                "onTextChanged": {
                  "type": "code",
                  "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetLargeHauler[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetLargeHauler[\"\"]\n}"
                },
                "onTabPress": {
                  "type": "code",
                  "code": "LGUI2.Element[tbMiningShip]:KeyboardFocus"
                }
              },
              "font": {
                "height": 36
              }
            },
            {
              "type": "textblock",
              "name": "lblMiningShip",
              "x": 30,
              "y": 160,
              "width": 300,
              "height": 54,
              "text": "Mining Ship:",
              "font": {
                "height": 36
              }
            },
            {
              "type": "textbox",
              "name": "tbMiningShip",
              "x": 270,
              "y": 160,
              "width": 400,
              "height": 48,
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "Mining Ship."
              },
              "eventHandlers": {
                "onLoad": {
                  "type": "code",
                  "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Missioneer.MiningShip}]"
                },
                "onTextChanged": {
                  "type": "code",
                  "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetMiningShip[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetMiningShip[\"\"]\n}"
                },
                "onTabPress": {
                  "type": "code",
                  "code": "LGUI2.Element[tbCombatShip]:KeyboardFocus"
                }
              },
              "font": {
                "height": 36
              }
            },
            {
              "type": "textblock",
              "name": "lblCombatShip",
              "x": 30,
              "y": 220,
              "width": 300,
              "height": 54,
              "text": "Combat Ship:",
              "font": {
                "height": 36
              }
            },
            {
              "type": "textbox",
              "name": "tbCombatShip",
              "x": 270,
              "y": 220,
              "width": 400,
              "height": 48,
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "Combat Ship."
              },
              "eventHandlers": {
                "onLoad": {
                  "type": "code",
                  "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Missioneer.CombatShip}]"
                },
                "onTextChanged": {
                  "type": "code",
                  "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetCombatShip[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetCombatShip[\"\"]\n}"
                },
                "onTabPress": {
                  "type": "code",
                  "code": "LGUI2.Element[tbSalvageShip]:KeyboardFocus"
                }
              },
              "font": {
                "height": 36
              }
            }
          ]
        },
        {
          "jsonTemplate": "evebotBorderedPanel",
          "name": "frmSalvageOptions",
          "x": 10,
          "y": 380,
          "width": 1240,
          "height": 120,
          "children": [
            {
              "type": "textblock",
              "name": "lblSalvageMode",
              "x": 30,
              "y": 36,
              "width": 330,
              "height": 54,
              "text": "Salvage Mode:",
              "font": {
                "height": 36
              }
            },
            {
              "type": "combobox",
              "name": "comboSalvageMode",
              "x": 220,
              "y": 30,
              "width": 165,
              "height": 54,
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "Solo = switch to salvage ship.  Relay = relay to salvage bot."
              },
              "font": {
                "height": 36
              },
              "eventHandlers": {
                "onSelectionChanged": {
                  "type": "code",
                  "code": "Script[EVEBot].VariableScope.UI:OnSalvageModeComboBoxChanged[]"
                }
              },
              "popup": {
                "type": "popup",
                "minSize": [
                  0,
                  200
                ],
                "content": {
                  "type": "listbox",
                  "name": "comboSalvageModeList",
                  "width": 165,
                  "height": 60,
                  "font": {
                    "height": 36
                  },
                  "minSize": [
                    0,
                    200
                  ],
                  "items": [
                    {
                      "type": "textblock",
                      "text": "None",
                      "font": {
                        "height": 36
                      }
                    },
                    {
                      "type": "textblock",
                      "text": "Solo",
                      "font": {
                        "height": 36
                      }
                    },
                    {
                      "type": "textblock",
                      "text": "Relay",
                      "font": {
                        "height": 36
                      }
                    }
                  ],
                  "eventHandlers": {
                    "onItemSelected": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxItemSelected"
                    },
                    "onItemDeselected": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxItemDeselected"
                    },
                    "onSelectionChanged": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxSelectionChanged"
                    }
                  }
                },
                "contentContainer": {
                  "jsonTemplate": "popup.panel",
                  "width": 165,
                  "height": 60,
                  "minSize": [
                    0,
                    200
                  ],
                  "type": "anchor",
                  "anchorToElement": {
                    "elementType": "combobox",
                    "elementTree": "logical",
                    "flags": "ancestor"
                  },
                  "clipToParent": false,
                  "anchorLocationFactor": [
                    0.0,
                    1.0
                  ]
                }
              }
            },
            {
              "type": "textblock",
              "name": "lblSalvageShip",
              "x": 470,
              "y": 30,
              "width": 300,
              "height": 54,
              "text": "Salvage Ship:",
              "font": {
                "height": 36
              }
            },
            {
              "type": "textbox",
              "name": "tbSalvageShip",
              "x": 710,
              "y": 30,
              "width": 400,
              "height": 48,
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "Ship to use for solo salvaging."
              },
              "eventHandlers": {
                "onLoad": {
                  "type": "code",
                  "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Missioneer.SalvageShip}]"
                },
                "onTextChanged": {
                  "type": "code",
                  "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetSalvageShip[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetSalvageShip[\"\"]\n}"
                },
                "onTabPress": {
                  "type": "code",
                  "code": "LGUI2.Element[tbSmallHaulerLimit]:KeyboardFocus"
                }
              },
              "font": {
                "height": 36
              }
            }
          ]
        },
        {
          "jsonTemplate": "evebotBorderedPanel",
          "name": "frmGeneralOptions",
          "x": 10,
          "y": 520,
          "width": 1240,
          "height": 120,
          "children": [
            {
              "type": "checkbox",
              "name": "cbAvoidLowSec",
              "x": 30,
              "y": 30,
              "width": 360,
              "height": 60,
              "content": "Avoid Lowsec",
              "contentContainer": {
                "jsonTemplate": "evebotCheckboxContainer"
              },
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "If checked, avoid missions that go into low-sec."
              },
              "checkedBinding": {
                "pullFormat": "${Script[EVEBot].VariableScope.Config.Missioneer.AvoidLowSec}",
                "pushFormat": ["Script[EVEBot].VariableScope.Config.Missioneer:SetAvoidLowSec[", "]"]
              }
            },
            {
              "type": "textblock",
              "name": "lblSmallHaulerLimit",
              "x": 470,
              "y": 39,
              "width": 480,
              "height": 54,
              "text": "Small Hauler Limit:",
              "font": {
                "height": 36
              }
            },
            {
              "type": "textbox",
              "name": "tbSmallHaulerLimit",
              "x": 710,
              "y": 30,
              "width": 150,
              "height": 48,
              "tooltip": {
                "jsonTemplate": "evebotTooltip",
                "text": "Will use the large hauler for missions above this limit."
              },
              "eventHandlers": {
                "onLoad": {
                  "type": "code",
                  "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Missioneer.SmallHaulerLimit}]"
                },
                "onTextChanged": {
                  "type": "code",
                  "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetSmallHaulerLimit[${Int[${This.Text}]}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Missioneer:SetSmallHaulerLimit[0]\n}"
                },
                "onTabPress": {
                  "type": "code",
                  "code": "LGUI2.Element[tbSmallHauler]:KeyboardFocus"
                }
              },
              "font": {
                "height": 36
              }
            }
          ]
        }
      ]
    }
  }
}