{
  "$schema": "http://www.lavishsoft.com/schema/lgui2Package.json",
  "elements": [
    {
      "type": "window",
      "name": "EVEBot",
      "x": 1045,
      "y": 775,
      "width": 1490,
      "height": 1005,
      "eventHandlers": {
        "onCloseButtonClick": {
          "type": "code",
          "code": "EVEBot:EndBot[]"
        }
      },
      "titleBar": {
        "jsonTemplate": "evebotTitleBar"
      },
      "content": {
        "type": "tabcontrol",
        "name": "EVEBotOptionsTab",
        "x": 0,
        "y": 5,
        "width": "100%",
        "height": "100%",
        "tabs": [
          {
            "type": "tab",
            "header": "Status",
            "content": {
              "jsonTemplate": "tabStatus.content"
            }
          },
          {
            "type": "tab",
            "header": "Main",
            "content": {
              "jsonTemplate": "tabMain.content"
            }
          },
          {
            "type": "tab",
            "header": "Miner",
            "content": {
              "jsonTemplate": "tabMiner.content"
            }
          },
          {
            "type": "tab",
            "header": "Combat",
            "content": {
              "jsonTemplate": "tabCombat.content"
            }
          },
          {
            "type": "tab",
            "header": "Hauler",
            "content": {
              "jsonTemplate": "tabHauler.content"
            }
          },
          {
            "type": "tab",
            "header": "Labels",
            "content": {
              "jsonTemplate": "tabLabels.content"
            }
          },
          {
            "type": "tab",
            "header": "Freighter",
            "content": {
              "jsonTemplate": "tabFreighter.content"
            }
          },
          {
            "type": "tab",
            "header": "Fleet",
            "content": {
              "jsonTemplate": "tabFleet.content"
            }
          },
          {
            "type": "tab",
            "header": "Missions",
            "content": {
              "jsonTemplate": "tabMissions.content"
            }
          },
          {
            "type": "tab",
            "header": "Fleeing",
            "content": {
              "jsonTemplate": "tabFleeing.content"
            }
          }
        ]
      },
      "font": {
        "face": "Segoe UI",
        "height": 36
      }
    }
  ]
}
