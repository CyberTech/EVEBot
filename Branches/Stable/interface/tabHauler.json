{
  "$schema": "http://www.lavishsoft.com/schema/lgui2Package.json",
  "templates": {
    "tabHauler.content": {
      "type": "panel",
      "children": [
        {
          "type": "textblock",
          "name": "HaulerModeLabel",
          "x": 30,
          "y": 30,
          "width": 210,
          "height": 30,
          "text": "Mode: ",
          "font": {
            "height": 36
          }
        },
        {
          "type": "combobox",
          "name": "HaulerMode",
          "x": 240,
          "y": 30,
          "width": 750,
          "height": 45,
          "font": {
            "height": 36
          },
          "eventHandlers": {
            "onSelectionChanged": {
              "type": "code",
              "code": "if ${This.SelectedItem.Data.Get[text].NotNULLOrEmpty}\n{\n\tScript[EVEBot].VariableScope.Config.Hauler:SetHaulerMode[${This.SelectedItem.Data.Get[text]}]\n\tScript[EVEBot].VariableScope.Config.Hauler:SetHaulerModeName[${This.SelectedItem.Data.Get[text]}]\n}"
            }
          },
          "popup": {
            "type": "popup",
            "minSize": [
              0,
              200
            ],
            "content": {
              "type": "listbox",
              "name": "HaulerModeList",
              "width": 750,
              "height": 60,
              "font": {
                "height": 36
              },
              "minSize": [
                0,
                200
              ],
              "items": [
                {
                  "type": "textblock",
                  "text": "Service Fleet Members",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Service On-Demand",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Service Orca",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Jetcan Mode (Flip-guard)",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Service Fleet Member",
                  "font": {
                    "height": 36
                  }
                }
              ],
              "eventHandlers": {
                "onItemSelected": {
                  "type": "forward",
                  "elementType": "combobox",
                  "event": "onListBoxItemSelected"
                },
                "onItemDeselected": {
                  "type": "forward",
                  "elementType": "combobox",
                  "event": "onListBoxItemDeselected"
                },
                "onSelectionChanged": {
                  "type": "forward",
                  "elementType": "combobox",
                  "event": "onListBoxSelectionChanged"
                }
              }
            },
            "contentContainer": {
              "jsonTemplate": "popup.panel",
              "width": 750,
              "height": 60,
              "minSize": [
                0,
                200
              ],
              "type": "anchor",
              "anchorToElement": {
                "elementType": "combobox",
                "elementTree": "logical",
                "flags": "ancestor"
              },
              "clipToParent": false,
              "anchorLocationFactor": [
                0.0,
                1.0
              ]
            }
          }
        },
        {
          "type": "checkbox",
          "name": "cbOrcaRunningEvebot",
          "x": 30,
          "y": 90,
          "height": 60,
          "width": 300,
          "content": "Orca is running EVEBot",
          "contentContainer": {
            "jsonTemplate": "evebotCheckboxContainer"
          },
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "When checked, the hauler will wait at dropoff location for orca to broadcast cargo used. When unchecked, hauler will cycle endlessly without breaks."
          },
          "checkedBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Hauler.OrcaRunningEvebot}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Hauler:SetOrcaRunningEvebot[", "]"]
          }
        },
        {
          "type": "textblock",
          "name": "HaulerPickupLabel",
          "x": 30,
          "y": 180,
          "width": 540,
          "height": 30,
          "text": "Pickup Location",
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The name of the fleet member flying your orca"
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "HaulerPickupName",
          "x": 600,
          "y": 180,
          "width": 750,
          "height": 48,
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Hauler.HaulerPickupName}]"
            },
            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Hauler:SetHaulerPickupName[${This.Text}]\n}"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "textblock",
          "name": "MiningSystemLabel",
          "x": 30,
          "y": 240,
          "width": 540,
          "height": 30,
          "text": "Mining System Bookmark",
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The bookmark name for the mining system location."
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "MiningSystemBookmark",
          "x": 600,
          "y": 240,
          "width": 750,
          "height": 48,
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Hauler.MiningSystemBookmark}]"
            },
            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Hauler:SetMiningSystemBookmark[${This.Text}]\n}"
            }
          },
          "font": {
            "height": 36
          }
        }
      ]
    }
  }
}