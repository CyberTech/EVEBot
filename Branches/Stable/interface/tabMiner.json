            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Miner:SetMiningRangeMultipler[${This.Text}]\n}"
            }
          },
          "font": {
            "height": 36
