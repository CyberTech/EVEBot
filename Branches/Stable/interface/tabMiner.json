          "contentContainer": {
            "jsonTemplate": "evebotCheckboxContainer"
          },
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Strip Mine the immediate area to nothing before moving"
          },
          "checkedBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Miner.StripMine}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Miner:SetStripMine[", "]"]
          }
        },
        {
          "type": "checkbox",
          "name": "cbBookMarkLastPosition",
