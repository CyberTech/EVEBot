            "jsonTemplate": "evebotCheckboxContainer"
          },
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Will bookmark the last mining location when the hold fills, and return to that spot after emptying the hold."
          },
          "checkedBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Miner.BookMarkLastPosition}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Miner:SetBookMarkLastPosition[", "]"]
          }
