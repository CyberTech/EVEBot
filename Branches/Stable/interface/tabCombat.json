        {
          "type": "checkbox",
          "name": "cbAlwaysShieldBoost",
          "x": 10,
          "y": 10,
          "height": 60,
          "width": 300,
          "content": "Always Shield Boost",
          "contentContainer": {
            "jsonTemplate": "evebotCheckboxContainer"
          },
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Turn Shield Booster on full-time, instead of on-demand."
          },
          "checkedBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Combat.AlwaysShieldBoost}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Combat:SetAlwaysShieldBoost[", "]"]
          }
        },
        {
          "type": "textblock",
          "name": "MinimumDronesInSpaceText",
          "x": 600,
          "y": 20,
          "width": 600,
          "height": 30,
          "text": "Min. Available Drones:",
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "MinimumDronesInSpace",
          "x": 1000,
          "y": 20,
          "width": 70,
          "height": 48,
          "maxLength": 2,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Bot will return to base when available drones falls below this number"
          },
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Combat.MinimumDronesInSpace}]"
            },
            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Combat:SetMinimumDronesInSpace[${Int[${This.Text}]}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Combat:SetMinimumDronesInSpace[0]\n}"
            },
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[WarpRange]:KeyboardFocus"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "checkbox",
          "name": "cbLaunchCombatDrones",
          "x": 10,
