{
  "$schema": "http://www.lavishsoft.com/schema/lgui2Package.json",
  "templates": {
    "tabFreighter.content": {
      "type": "panel",
      "horizontalAlignment": "stretch",
      "verticalAlignment": "stretch",
      "children": [
        {
          "type": "textblock",
          "name": "lblFreighterMode",
          "x": 10,
          "y": 30,
          "width": 210,
          "height": 30,
          "text": "Mode: ",
          "font": {
            "height": 36
          }
        },
        {
          "type": "combobox",
          "name": "cbFreighterMode",
          "x": 300,
          "y": 30,
          "width": 675,
          "height": 45,
          "font": {
              "height": 36
          },
          "eventHandlers": {
            "onSelectionChanged": {
              "type": "code",
              "code": "Script[EVEBot].VariableScope.UI:OnFreighterModeComboBoxChanged[]"
            }
          },
          "popup": {
            "type": "popup",
            "minSize": [ 0, 200 ],
            "content": {
              "type": "listbox",
              "name": "cbFreighterModeList",
              "width": 675,
              "height": 60,
              "font": {
                "height": 36
              },
              "minSize": [ 0, 200 ],
              "items": [
                {
                  "type": "textblock",
                  "text": "Source and Destination",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Asset Gather",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Move Minerals to Buyer",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Container Test",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Mission Runner",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Stealth Hauler",
                  "font": {
                    "height": 36
                  }
                },
                {
                  "type": "textblock",
                  "text": "Scavenger",
                  "font": {
                    "height": 36
                  }
                }
              ],
              "eventHandlers": {
                  "onItemSelected": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxItemSelected"
                  },
                  "onItemDeselected": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxItemDeselected"
                  },
                  "onSelectionChanged": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxSelectionChanged"
                  }
              }
            },
            "contentContainer":{
                "jsonTemplate":"popup.panel",
                "width": 675,
                "height": 60,
                "minSize": [ 0, 200 ],
                "type":"anchor",
                "anchorToElement":{
                    "elementType":"combobox",
                    "elementTree":"logical",
                    "flags":"ancestor"
                },
                "clipToParent":false,
                "anchorLocationFactor":[0.0,1.0]
            }
          }
        },
        {
          "type": "textblock",
          "name": "lblDestination",
          "x": 10,
          "y": 150,
          "width": 300,
          "height": 40,
          "text": "Destination:",
          "font": {
            "height": 36
          }
        },
        {
          "type": "combobox",
          "name": "teDestination",
          "x": 300,
          "y": 150,
          "width": 675,
          "height": 45,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The destination bookmark."
          },
          "font": {
              "height": 36
          },
          "eventHandlers": {
            "onSelectionChanged": {
              "type": "code",
              "code": "if ${This.SelectedItem.Data.Get[text].NotNULLOrEmpty}\n{\n\tLogger:Log[\"Freighter destination set to ${This.SelectedItem.Data.Get[text]}\"]\n\tScript[EVEBot].VariableScope.Config.Freighter:SetDestination[${This.SelectedItem.Data.Get[text]}]\n}"
            }
          },
          "popup": {
            "type": "popup",
            "minSize": [ 0, 200 ],
            "content": {
              "type": "listbox",
              "name": "teDestinationList",
              "width": 675,
              "height": 60,
              "font": {
                "height": 36
              },
              "minSize": [ 0, 200 ],
              "itemsBinding": {
                "pullFormat": "${Script[EVEBot].VariableScope.UI.GetFreighterDestinations}"
              },
              "eventHandlers": {
                  "onItemSelected": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxItemSelected"
                  },
                  "onItemDeselected": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxItemDeselected"
                  },
                  "onSelectionChanged": {
                      "type": "forward",
                      "elementType": "combobox",
                      "event": "onListBoxSelectionChanged"
                  }
              }
            },
            "contentContainer":{
                "jsonTemplate":"popup.panel",
                "width": 675,
                "height": 60,
                "minSize": [ 0, 200 ],
                "type":"anchor",
                "anchorToElement":{
                    "elementType":"combobox",
                    "elementTree":"logical",
                    "flags":"ancestor"
                },
                "clipToParent":false,
                "anchorLocationFactor":[0.0,1.0]
            }
          }
        },
        {
          "type": "textblock",
          "name": "lblFilters",
          "x": 10,
          "y": 220,
          "width": 300,
          "height": 40,
          "text": "Filters:",
          "font": {
            "height": 36,
            "bold": true
          }
        },
        {
          "type": "textblock",
          "name": "lblSourcePrefix",
          "x": 30,
          "y": 250,
          "width": 350,
          "height": 40,
          "text": "Source Bookmark Prefix:",
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "teSourcePrefix",
          "x": 350,
          "y": 250,
          "width": 300,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The prefix for source bookmark names."
          },
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Freighter.SourcePrefix}]"
            },
            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Freighter:SetSourcePrefix[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Freighter:SetSourcePrefix[\"\"]\n}"
            },
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[teRegionName]:KeyboardFocus"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "button",
          "name": "Refresh Bookmarks",
          "x": 690,
          "y": 260,
          "width": 230,
          "height": 90,
          "content": "Refresh Bookmarks\n     (Apply Filters)",
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Refresh list of bookmarks utilizing the prefix and limitations set below"
          },
          "eventHandlers": {
            "onPress": {
              "type": "code",
              "code": "Freighter:BuildSourceList"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "textblock",
          "name": "lblRegionName",
          "x": 30,
          "y": 310,
          "width": 300,
          "height": 40,
          "text": "Limit To Region:",
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "teRegionName",
          "x": 350,
          "y": 310,
          "width": 300,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Leave blank to service all regions."
          },
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Freighter.RegionName}]"
            },
            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Freighter:SetRegionName[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Freighter:SetRegionName[\"\"]\n}"
            },
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[teSourcePrefix]:KeyboardFocus"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "listbox",
          "name": "PickupBookmarks",
          "x": 0,
          "y": 400,
          "height": 470,
          "horizontalAlignment": "stretch",
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Bookmarks which will be visited to pickup items"
          }
        }
      ]
    }
  }
}