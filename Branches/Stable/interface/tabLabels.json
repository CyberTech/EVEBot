{
  "$schema": "http://www.lavishsoft.com/schema/lgui2Package.json",
  "templates": {
    "tabLabels.content": {
      "type": "panel",
      "horizontalAlignment": "stretch",
      "verticalAlignment": "stretch",
      "children": [
        {
          "type": "textblock",
          "name": "Label1",
          "x": 10,
          "y": 30,
          "width": 600,
          "height": 40,
          "text": "Bookmark Prefixes",
          "font": {
            "height": 36,
            "bold": true
          }
        },
        {
          "type": "textblock",
          "name": "SafeSpotsLabel",
          "x": 30,
          "y": 90,
          "width": 300,
          "height": 30,
          "text": "Safe Spots:",
          "font": {
            "height": 36
          }
        },
        {
          "jsonTemplate": "evebotTextBox",
          "name": "SafeSpotPrefix",
          "x": 350,
          "y": 90,
          "width": 250,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The prefix for safe spot bookmark names."
          },
          "textBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Labels.SafeSpotPrefix}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Labels:SetSafeSpotPrefix[", "]"]
          },
          "eventHandlers": {
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[BeltBookMarkPrefix]:KeyboardFocus"
            }
          }
        },
        {
          "type": "textblock",
          "name": "BeltBookMarkLabel",
          "x": 30,
          "y": 150,
          "width": 300,
          "height": 40,
          "text": "Ore Belts:",
          "font": {
            "height": 36
          }
        },
        {
          "jsonTemplate": "evebotTextBox",
          "name": "BeltBookMarkPrefix",
          "x": 350,
          "y": 150,
          "width": 250,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The prefix for ore belt bookmark names."
          },
          "textBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Labels.OreBeltPrefix}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Labels:SetOreBeltPrefix[", "]"]
          },
          "eventHandlers": {
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[IceBeltBookMarkPrefix]:KeyboardFocus"
            }
          }
        },
        {
          "type": "textblock",
          "name": "IceBeltBookMarkLabel",
          "x": 30,
          "y": 210,
          "width": 300,
          "height": 40,
          "text": "Ice Belts:",
          "font": {
            "height": 36
          }
        },
        {
          "jsonTemplate": "evebotTextBox",
          "name": "IceBeltBookMarkPrefix",
          "x": 350,
          "y": 210,
          "width": 250,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The prefix for ice belt bookmark names."
          },
          "textBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Labels.IceBeltPrefix}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Labels:SetIceBeltPrefix[", "]"]
          },
          "eventHandlers": {
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[AmmoBookMarkPrefix]:KeyboardFocus"
            }
          }
        },
        {
          "type": "textblock",
          "name": "AmmoBookMarkLabel",
          "x": 30,
          "y": 270,
          "width": 300,
          "height": 40,
          "text": "Ammo Supplies:",
          "font": {
            "height": 36
          }
        },
        {
          "jsonTemplate": "evebotTextBox",
          "name": "AmmoBookMarkPrefix",
          "x": 350,
          "y": 270,
          "width": 250,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The prefix for Ammo bookmark names."
          },
          "textBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Labels.AmmoPrefix}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Labels:SetAmmoPrefix[", "]"]
          },
          "eventHandlers": {
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[UndockInstaTag]:KeyboardFocus"
            }
          }
        },
        {
          "type": "textblock",
          "name": "UndockInstaTagLabel",
          "x": 30,
          "y": 330,
          "width": 300,
          "height": 40,
          "text": "Tag for Undock Instas:",
          "font": {
            "height": 36
          }
        },
        {
          "jsonTemplate": "evebotTextBox",
          "name": "UndockInstaTag",
          "x": 350,
          "y": 330,
          "width": 250,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The string that undock insta bookmarks will contain. 1 space will be prepended and appended."
          },
          "textBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Labels.InstaUndockTag}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Labels:InstaUndockTag[", "]"]
          },
          "eventHandlers": {
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[DockInstaTag]:KeyboardFocus"
            }
          }
        },
        {
          "type": "textblock",
          "name": "DockInstaTagLabel",
          "x": 30,
          "y": 390,
          "width": 400,
          "height": 40,
          "text": "Tag for Dock Instas:",
          "font": {
            "height": 36
          }
        },
        {
          "jsonTemplate": "evebotTextBox",
          "name": "DockInstaTag",
          "x": 350,
          "y": 390,
          "width": 250,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The string that dock insta bookmarks will contain. 1 space will be prepended and appended."
          },
          "textBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Labels.InstaDockTag}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Labels:InstaDockTag[", "]"]
          },
          "eventHandlers": {
            "onTabPress": {
              "type": "code",
              "code": "LGUI2.Element[SafeSpotPrefix]:KeyboardFocus"
            }
          }
        }
      ]
    }
  }
}