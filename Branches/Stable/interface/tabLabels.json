{
  "$schema": "http://www.lavishsoft.com/schema/lgui2Package.json",
  "templates": {
    "tabLabels.content": {
      "type": "panel",
      "children": [
        {
          "type": "textblock",
          "name": "Label1",
          "x": 30,
          "y": 30,
          "width": 600,
          "height": 30,
          "text": "Bookmark Prefixes",
          "font": {
            "height": 36
          }
        },
        {
          "type": "textblock",
          "name": "SafeSpotsLabel",
          "x": 75,
          "y": 75,
          "width": 600,
          "height": 30,
          "text": "Safe Spots",
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "The prefix for safe spot bookmark names."
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "SafeSpotPrefix",
          "x": 690,
          "y": 75,
          "width": 300,
          "height": 48,
          "maxLength": 10,
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Labels.SafeSpotPrefix}]"
            },
            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Labels:SetSafeSpotPrefix[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Labels:SetSafeSpotPrefix[\"\"]\n}"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "textblock",
          "name": "BeltBookMarkLabel",
