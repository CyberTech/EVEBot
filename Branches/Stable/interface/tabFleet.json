{
  "$schema": "http://www.lavishsoft.com/schema/lgui2Package.json",
  "templates": {
    "tabFleet.content": {
      "type": "panel",
      "horizontalAlignment": "stretch",
      "verticalAlignment": "stretch",
      "children": [
        {
          "type": "checkbox",
          "name": "cbUseFleet",
          "x": 10,
          "y": 30,
          "width": 300,
          "height": 60,
          "content": "Manage Fleet",
          "contentContainer": {
            "jsonTemplate": "evebotCheckboxContainer"
          },
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "If checked, EVEBot will manage your fleet"
          },
          "checkedBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Fleet.ManageFleet}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Fleet:SetManageFleet[", "]"]
          }
        },
        {
          "type": "textblock",
          "name": "label2",
          "x": 400,
          "y": 40,
          "width": 600,
          "height": 54,
          "text": "Accept invites from:",
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "tbFleetLeader",
          "x": 700,
          "y": 40,
          "width": 450,
          "height": 48,
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "This:SetText[${Script[EVEBot].VariableScope.Config.Fleet.FleetLeader}]"
            },
            "onTextChanged": {
              "type": "code",
              "code": "if ${This.Text.Length} > 0\n{\n\tScript[EVEBot].VariableScope.Config.Fleet:SetFleetLeader[${This.Text}]\n}\nelse\n{\n\tScript[EVEBot].VariableScope.Config.Fleet:SetFleetLeader[\"\"]\n}"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "checkbox",
          "name": "cbIsLeader",
          "x": 10,
          "y": 120,
          "width": 300,
          "height": 60,
          "content": "I am the leader",
          "contentContainer": {
            "jsonTemplate": "evebotCheckboxContainer"
          },
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "If checked, this character will invite your fleet.  Don't set more than one!"
          },
          "checkedBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Fleet.IsLeader}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Fleet:SetIsLeader[", "]"]
          }
        },
        {
          "type": "textblock",
          "name": "Label1",
          "x": 400,
          "y": 130,
          "width": 600,
          "height": 40,
          "text": "Manage Fleet Member:",
          "font": {
            "height": 36
          }
        },
        {
          "type": "textbox",
          "name": "tbAddFleetMember",
          "x": 700,
          "y": 130,
          "width": 450,
          "height": 48,
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "Use this to add members to your fleet.  They must be in your corporation or in your contacts list."
          },
          "eventHandlers": {
            "onTextChanged": {
              "type": "code",
              "code": "if ${Script[EVEBot].VariableScope.Config.Fleet.IsWing[\"${This.Text.Escape}\"]}\n\tLGUI2.Element[cbWing]:SetChecked\nelse\n\tLGUI2.Element[cbWing]:UnsetChecked"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "button",
          "name": "AddFleetMember",
          "x": 1175,
          "y": 130,
          "width": 40,
          "height": 48,
          "content": "+",
          "eventHandlers": {
            "onChecked": {
              "type": "code",
              "code": "Script[EVEBot].VariableScope.Config.Fleet:SetIsLeader[TRUE]\nif TRUE\n{\n\tLGUI2.Element[tbFleetLeader]:SetText[]\n}"
            },
            "onUnchecked": {
              "type": "code",
              "code": "Script[EVEBot].VariableScope.Config.Fleet:SetIsLeader[FALSE]\nif FALSE\n{\n\tLGUI2.Element[tbFleetLeader]:SetText[]\n}"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "button",
          "name": "RemoveFleetMember",
          "x": 1230,
          "y": 130,
          "width": 40,
          "height": 48,
          "content": "-",
          "eventHandlers": {
            "onChecked": {
              "type": "code",
              "code": "Script[EVEBot].VariableScope.Config.Fleet:SetIsLeader[TRUE]\nif TRUE\n{\n\tLGUI2.Element[tbFleetLeader]:SetText[]\n}"
            },
            "onUnchecked": {
              "type": "code",
              "code": "Script[EVEBot].VariableScope.Config.Fleet:SetIsLeader[FALSE]\nif FALSE\n{\n\tLGUI2.Element[tbFleetLeader]:SetText[]\n}"
            }
          },
          "font": {
            "height": 36
          }
        },
        {
          "type": "checkbox",
          "name": "cbWing",
          "x": 1300,
          "y": 130,
          "width": 270,
          "height": 60,
          "content": "Wing 2",
          "contentContainer": {
            "jsonTemplate": "evebotCheckboxContainer"
          },
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "If checked, this character will be moved to Wing 2.\nUsed for characters you don't want warped with your fleet."
          },
          "checkedBinding": {
            "pullFormat": "${Script[EVEBot].VariableScope.Config.Fleet.WingOne}",
            "pushFormat": ["Script[EVEBot].VariableScope.Config.Fleet:SetWingOne[", "]"]
          }
        },
        {
          "type": "listbox",
          "name": "FleetMembers",
          "x": 0,
          "y": 250,
          "height": 620,
          "horizontalAlignment": "stretch",
          "tooltip": {
            "jsonTemplate": "evebotTooltip",
            "text": "These characters will be added to your fleet if EVEBot can find them in your Corporation or Contacts and \"I am Leader\" is checked."
          },
          "eventHandlers": {
            "onLoad": {
              "type": "code",
              "code": "Script[EVEBot].VariableScope.Config.Fleet:RefreshFleetMembers\nvariable iterator InfoFromSettings\nScript[EVEBot].VariableScope.Config.Fleet.FleetMembers:GetIterator[InfoFromSettings]\nif ${InfoFromSettings:First(exists)}\n{\n\tdo\n\t{\n\t\tThis:AddItem[${InfoFromSettings.Value.FleetMemberName}]\n\t}\n\twhile ${InfoFromSettings:Next(exists)}\n}"
            },
            "onSelectionChanged": {
              "type": "code",
              "code": "LGUI2.Element[tbAddFleetMember]:SetText[${This.SelectedItem.Data.Get[text]}]\nif ${Script[EVEBot].VariableScope.Config.Fleet.IsWing[${LGUI2.Element[tbAddFleetMember].Text}]}\n\tLGUI2.Element[cbWing]:SetChecked\nelse\n\tLGUI2.Element[cbWing]:UnsetChecked"
            }
          }
        }
      ]
    }
  }
}